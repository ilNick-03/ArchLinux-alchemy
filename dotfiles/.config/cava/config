## --- CAVA: VISUAL ALCHEMY CONFIGURATION ---
## Optimized for Sweet Ambar Blue / Plasma Burn palettes
## Tuned for Pipewire (48k) and 60Hz high-fidelity rendering


[general]
# Synced with display refresh rate for fluid motion
framerate = 60
#framerate = 144

# Dynamic sensitivity: prevents clipping during peak transients
autosens = 1
sensitivity = 100

# Geometry: 0 for automatic terminal width filling
bars = 0
bar_width = 2
bar_spacing = 1
center_align = 1


[input]
# Pipewire backend: direct stream interception
method = pipewire
source = auto

# Matches internal Pipewire sample rate for 1:1 spectral accuracy
sample_rate = 48000
# 32-bit depth to match internal audio processing resolution
sample_bits = 32


[output]
# 'noncurses' ensures low latency and reduced tearing in modern terminals
method = noncurses
orientation = bottom
channels = stereo


[color]
# Transparency support: inherits terminal background
background = default
foreground = default

# Gradient Engine: active with 8-bit color depth
gradient = 1
gradient_count = 8



