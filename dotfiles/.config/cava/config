[smoothing]
# Monstercat algorithm: provides an organic, fluid visual flow
monstercat = 1
waves = 0

# Response speed: 50 balances smoothness with technical precision
# 100 is very slow/smooth, 0 is fast/noisy.
noise_reduction = 50


[eq]
# Flat equalization for an honest spectral representation
; 1 = 1 # bass
; 2 = 1
; 3 = 1 # midtone
; 4 = 1
; 5 = 1 # treble
