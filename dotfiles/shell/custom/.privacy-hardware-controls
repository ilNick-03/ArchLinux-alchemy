# ===== PRIVACY & HARDWARE CONTROLS =====
# This file provides low-level interfaces for display, camera, and microphone manipulation.
# Designed for Linux environments using PipeWire and UVC-compliant webcams.


# --- Camera Control: Loads/Unloads the UVC Video kernel module ---
# Note: Requires sudo privileges for kernel manipulation.
camera-off() {
    sudo modprobe -r uvcvideo && echo "SUCCESS: Camera module (uvcvideo) unloaded."
}

camera-on() {
    sudo modprobe uvcvideo && echo "SUCCESS: Camera module (uvcvideo) loaded."
}

# --- Microphone Control: Manages the default audio source via PipeWire/Wireplumber ---
# Directly interacts with the PipeWire sound server to seal audio input.
mic-off() {
    wpctl set-mute @DEFAULT_AUDIO_SOURCE@ 1 && echo "SUCCESS: Microphone muted."
}

mic-on() {
    wpctl set-mute @DEFAULT_AUDIO_SOURCE@ 0 && echo "SUCCESS: Microphone unmuted."
}


# --- Status Scrying: Check hardware state and identify intrusive processes ---
privacy-status() {
    # Text styles (ANSI)
    local BOLD="\033[1m"
    local CYAN="\033[36m"
    local RED="\033[31m"
    local GREEN="\033[32m"
    local RESET="\033[0m"

    echo -e "${CYAN}в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®${RESET}"
    echo -e "${CYAN}в”Ӯ${RESET}  ${BOLD}у°’ғ  PRIVACY SYSTEM STATUS SCRYING${RESET}        ${CYAN}в”Ӯ${RESET}"
    echo -e "${CYAN}в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө${RESET}"

    # --- CAMERA SECTION ---
    local cam_state="${RED}у°„Җ DISABLED${RESET}"
    local cam_procs="n/a (module unloaded)"
    
    if lsmod | grep -q uvcvideo; then
        cam_state="${GREEN}у°„Җ ENABLED${RESET}"
        local raw_cam=$(lsof /dev/video* 2>/dev/null | awk 'NR>1 {print $1}' | sort -u | paste -sd ", " -)
        cam_procs="${raw_cam:-none}"
    fi
    echo -e "${CYAN}в”Ӯ${RESET}  ${BOLD}Camera:${RESET}      $cam_state"
    echo -e "${CYAN}в”Ӯ${RESET}  ${CYAN}в””в”Җ${RESET} Active:  $cam_procs"

    echo -e "${CYAN}в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө${RESET}"

    # --- MICROPHONE SECTION ---
    local mic_state="${RED}у°Қӯ MUTED${RESET}"
    if ! wpctl get-volume @DEFAULT_AUDIO_SOURCE@ | grep -q "MUTED"; then
        mic_state="${GREEN}у°Қ® ACTIVE${RESET}"
    fi
    
    local raw_mic=$(pactl list source-outputs | grep "application.name" | cut -d '"' -f 2 | sort -u | paste -sd ", " -)
    local mic_procs="${raw_mic:-none}"

    echo -e "${CYAN}в”Ӯ${RESET}  ${BOLD}Microphone:${RESET}  $mic_state"
    echo -e "${CYAN}в”Ӯ${RESET}  ${CYAN}в””в”Җ${RESET} Active:  $mic_procs"
    echo -e "${CYAN}в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ${RESET}"
}
